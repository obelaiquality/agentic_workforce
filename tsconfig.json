{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "types": ["node", "vite/client", "vitest/globals"],
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "useDefineForClassFields": true,
    "noEmit": true,
    "skipLibCheck": true,
    "strict": false
  },
  "include": ["src/shared/contracts.ts", "src/app/lib/apiClient.ts", "src/app/types/**/*.d.ts", "vite.config.ts", "vitest.config.ts"],
  "exclude": ["dist", "dist-server", "dist-sidecar", "node_modules", ".local", "output"]
}
