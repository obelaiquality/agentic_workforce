# Core app
API_PORT="8787"
# Required for standalone `npm run dev:api`. Browser preview must use the same value via `VITE_API_TOKEN`.
API_TOKEN="agentic-local-dev-token"

# Database
# Required. Default local bootstrap expects Postgres on 127.0.0.1:5433.
DATABASE_URL="postgresql://agentic:agentic@127.0.0.1:5433/agentic_workforce?schema=public"

# Local Qwen CLI fallback
QWEN_COMMAND="qwen"
QWEN_ARGS="--auth-type qwen-oauth --output-format text"

# Default local OpenAI-compatible runtime
# Required for local-first mode unless you explicitly route work to OpenAI.
ONPREM_QWEN_BASE_URL="http://127.0.0.1:8000/v1"
ONPREM_QWEN_API_KEY=""
ONPREM_QWEN_INFERENCE_BACKEND="mlx-lm"
ONPREM_QWEN_PLUGIN="qwen3.5-4b"
ONPREM_QWEN_MODEL="mlx-community/Qwen3.5-4B-4bit"
ONPREM_QWEN_REASONING_MODE="off"

# Optional secondary OpenAI-compatible provider
# Example: Ollama, local proxy, or another OpenAI-compatible gateway.
OPENAI_COMPAT_BASE_URL="http://127.0.0.1:11434/v1"
OPENAI_COMPAT_API_KEY=""
OPENAI_COMPAT_MODEL="gpt-4o-mini"

# Optional OpenAI Responses API
OPENAI_API_KEY=""
OPENAI_RESPONSES_BASE_URL="https://api.openai.com/v1"
OPENAI_RESPONSES_MODEL="gpt-5-nano"
OPENAI_RESPONSES_REASONING_EFFORT="medium"
OPENAI_RESPONSES_DAILY_BUDGET_USD="25"
OPENAI_RESPONSES_PER_RUN_BUDGET_USD="5"

# Optional advanced/internal settings live in `.env.advanced.example`.
