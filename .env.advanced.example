# Advanced execution tuning
EXECUTION_AUTO_INSTALL_ON_INFRA_FAILURE="false"
EXECUTION_COMMAND_TIMEOUT_MS="120000"
EXECUTION_MODEL_STEP_TIMEOUT_MS="120000"
EXECUTION_PATCH_TIMEOUT_MS="120000"

# Optional GitHub App / relay settings
GITHUB_APP_ID=""
GITHUB_APP_CLIENT_ID=""
GITHUB_APP_SLUG=""
GITHUB_APP_RELAY_BASE_URL=""

# Optional sidecar overrides
RUST_SIDECAR_AUTOSTART="true"
RUST_SIDECAR_ADDR="127.0.0.1:50051"
RUST_SIDECAR_BIN=""
RUST_SIDECAR_MANIFEST=""

# Optional distillation / teacher tooling
DISTILL_TEACHER_COMMAND="claude"
DISTILL_TEACHER_MODEL="opus"
DISTILL_TEACHER_TIMEOUT_MS="120000"
DISTILL_TEACHER_MAX_RPM="6"
DISTILL_TEACHER_MAX_CONCURRENCY="1"
DISTILL_TEACHER_DAILY_TOKEN_BUDGET="120000"
DISTILL_TEACHER_RETRY_BACKOFF_MS="2500"
DISTILL_TEACHER_MAX_RETRIES="3"

# Optional distillation trainer
DISTILL_TRAINER_BACKEND="hf-lora-local"
DISTILL_TRAINER_PYTHON="python3"
DISTILL_TRAINER_MAX_STEPS="40"
DISTILL_TRAINER_BATCH_SIZE="1"
DISTILL_TRAINER_GRAD_ACCUM="8"
DISTILL_TRAINER_LR="0.0002"
DISTILL_TRAINER_LORA_R="8"
DISTILL_TRAINER_LORA_ALPHA="16"
DISTILL_TRAINER_MAX_SEQ_LENGTH="1024"
DISTILL_TRAINER_ORPO_BETA="0.1"
DISTILL_TRAINER_TOOL_REWARD_SCALE="0.6"

# Optional distillation full-pass defaults
DISTILL_FULL_PASS_SAMPLE_COUNT="30"
DISTILL_FULL_PASS_RETRIEVAL_IDS="knowledge-001,knowledge-002"
DISTILL_FULL_PASS_MODELS="Qwen/Qwen3.5-0.8B,Qwen/Qwen3.5-4B"
DISTILL_FULL_PASS_STAGES="sft,orpo,tool_rl"
