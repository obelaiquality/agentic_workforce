{
  "name": "@figma/my-make-file",
  "main": "electron/main.mjs",
  "private": true,
  "version": "0.0.1",
  "description": "Next-Gen Agentic Coding desktop app with Qwen CLI orchestration and provider-factory architecture.",
  "author": "Neilslab",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "build:server": "tsup src/server/index.ts --format esm --platform node --out-dir dist-server --clean --external electron",
    "build:sidecar": "node scripts/build-sidecar.mjs",
    "build:desktop": "npm run build && npm run build:server && npm run build:sidecar",
    "dev": "vite",
    "doctor": "node scripts/doctor.mjs",
    "knowledge:import:docx": "node scripts/knowledge/import_docx_refs.mjs",
    "benchmarks:api": "node scripts/benchmarks/run_api_regression.mjs",
    "distill:doctor": "node scripts/distill/doctor.mjs",
    "distill:run:full": "node scripts/distill/run_full_pass.mjs",
    "dev:sidecar": "cargo run --manifest-path rust/sidecar/Cargo.toml",
    "dev:api": "tsx watch src/server/index.ts",
    "dev:desktop": "concurrently -k \"npm run dev\" \"wait-on tcp:5173 && electron electron/main.mjs\"",
    "bootstrap": "node scripts/bootstrap.mjs",
    "start:desktop": "npm run bootstrap && npm run dev:desktop",
    "pack:desktop": "npm run build:desktop && electron-builder --dir",
    "dist:desktop": "npm run build:desktop && electron-builder",
    "test": "vitest run",
    "test:e2e:desktop-acceptance": "node scripts/playwright/run_electron_desktop_acceptance.mjs",
    "test:e2e:followup:status-badge": "node scripts/playwright/run_followup_scenario.mjs --scenario status-badge",
    "test:e2e:followup:progress-bar": "node scripts/playwright/run_followup_scenario.mjs --scenario progress-bar",
    "test:e2e:followup:utility-module": "node scripts/playwright/run_followup_scenario.mjs --scenario utility-module",
    "test:e2e:followup:api-stop": "node scripts/playwright/run_followup_scenario.mjs --scenario api-stop",
    "test:e2e:followup:rename-component": "node scripts/playwright/run_followup_scenario.mjs --scenario rename-component",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "test:e2e:playwright": "bash scripts/playwright/run_e2e_critical_failover.sh"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@fastify/cors": "^10.0.1",
    "@grpc/grpc-js": "^1.12.6",
    "@grpc/proto-loader": "^0.7.13",
    "@mui/icons-material": "7.3.5",
    "@mui/material": "7.3.5",
    "@popperjs/core": "2.11.8",
    "@prisma/client": "^6.5.0",
    "@radix-ui/react-accordion": "1.2.3",
    "@radix-ui/react-alert-dialog": "1.1.6",
    "@radix-ui/react-aspect-ratio": "1.1.2",
    "@radix-ui/react-avatar": "1.1.3",
    "@radix-ui/react-checkbox": "1.1.4",
    "@radix-ui/react-collapsible": "1.1.3",
    "@radix-ui/react-context-menu": "2.2.6",
    "@radix-ui/react-dialog": "1.1.6",
    "@radix-ui/react-dropdown-menu": "2.1.6",
    "@radix-ui/react-hover-card": "1.1.6",
    "@radix-ui/react-label": "2.1.2",
    "@radix-ui/react-menubar": "1.1.6",
    "@radix-ui/react-navigation-menu": "1.2.5",
    "@radix-ui/react-popover": "1.1.6",
    "@radix-ui/react-progress": "1.1.2",
    "@radix-ui/react-radio-group": "1.2.3",
    "@radix-ui/react-scroll-area": "1.2.3",
    "@radix-ui/react-select": "2.1.6",
    "@radix-ui/react-separator": "1.1.2",
    "@radix-ui/react-slider": "1.2.3",
    "@radix-ui/react-slot": "1.1.2",
    "@radix-ui/react-switch": "1.1.3",
    "@radix-ui/react-tabs": "1.1.3",
    "@radix-ui/react-toggle": "1.1.2",
    "@radix-ui/react-toggle-group": "1.1.2",
    "@radix-ui/react-tooltip": "1.1.8",
    "@tanstack/react-query": "^5.75.5",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "3.6.0",
    "dotenv": "^16.4.7",
    "embla-carousel-react": "8.6.0",
    "fastify": "^5.2.1",
    "input-otp": "1.4.2",
    "lucide-react": "0.487.0",
    "motion": "12.23.24",
    "next-themes": "0.4.6",
    "react-day-picker": "8.10.1",
    "react-dnd": "16.0.1",
    "react-dnd-html5-backend": "16.0.1",
    "react-hook-form": "7.55.0",
    "react-popper": "2.3.0",
    "react-resizable-panels": "2.1.7",
    "react-responsive-masonry": "2.7.1",
    "react-router": "7.13.0",
    "react-slick": "0.31.0",
    "recharts": "2.15.2",
    "sonner": "2.0.3",
    "tailwind-merge": "3.2.0",
    "tw-animate-css": "1.3.8",
    "vaul": "1.1.2",
    "yaml": "^2.8.2",
    "zod": "^3.24.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "@tailwindcss/vite": "4.1.12",
    "@types/node": "^22.13.10",
    "@vitejs/plugin-react": "4.7.0",
    "concurrently": "^9.1.2",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "playwright-core": "^1.58.2",
    "prisma": "^6.5.0",
    "tailwindcss": "4.1.12",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "vite": "6.3.5",
    "vitest": "^3.0.8",
    "wait-on": "^8.0.3"
  },
  "peerDependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "pnpm": {
    "overrides": {
      "vite": "6.3.5"
    }
  },
  "build": {
    "appId": "com.neilslab.agenticcoding",
    "productName": "Next-Gen Agentic Coding",
    "afterSign": "scripts/notarize.mjs",
    "asarUnpack": [
      "dist-sidecar/**/*",
      "node_modules/.prisma/**/*",
      "node_modules/@prisma/**/*"
    ],
    "files": [
      "dist/**/*",
      "dist-server/**/*",
      "dist-sidecar/**/*",
      "electron/**/*",
      "prisma/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "directories": {
      "buildResources": "build-resources",
      "output": "release"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build-resources/entitlements.mac.plist",
      "entitlementsInherit": "build-resources/entitlements.mac.plist"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development"
    }
  }
}
