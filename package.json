{
  "name": "agentic-workforce",
  "main": "electron/main.mjs",
  "private": false,
  "version": "1.3.0",
  "description": "Local-first desktop coding agent for real repositories with verified execution and evidence-rich review.",
  "author": "Neilslab",
  "license": "MIT",
  "files": [
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    "package.json",
    "scripts/agentic-cli.mjs"
  ],
  "homepage": "https://github.com/obelaiquality/agentic_workforce",
  "bugs": {
    "url": "https://github.com/obelaiquality/agentic_workforce/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/obelaiquality/agentic_workforce.git"
  },
  "keywords": [
    "ai",
    "coding-agent",
    "developer-tools",
    "electron",
    "local-first",
    "openai-compatible"
  ],
  "bin": {
    "agentic-workforce": "./scripts/agentic-cli.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "scripts": {
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "build": "vite build",
    "build:server": "tsup src/server/index.ts --format esm --platform node --out-dir dist-server --clean --external electron",
    "build:sidecar": "node scripts/build-sidecar.mjs",
    "build:desktop": "npm run build && npm run build:server && npm run build:sidecar",
    "dev": "vite",
    "doctor": "node scripts/doctor.mjs",
    "check:docs": "node scripts/check-doc-links.mjs",
    "generate:icons": "python3 scripts/generate_release_icons.py",
    "lint": "node scripts/lint-workspace.mjs",
    "lint:code": "eslint src/",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "prepublishOnly": "node scripts/prevent-npm-publish.mjs",
    "release:checksums": "node scripts/generate-release-checksums.mjs",
    "release:notes": "node scripts/build-release-notes.mjs",
    "security:check": "node scripts/security-guardrails.mjs",
    "secrets:check": "node scripts/check-no-secrets.mjs",
    "sbom:prod": "node scripts/generate-production-sbom.mjs docs/sbom.production.cdx.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:strict": "tsc --noEmit -p tsconfig.strict.json",
    "validate": "npm run lint && npm run security:check && npm run secrets:check && npm run audit:prod && npm run typecheck && npm run check:docs && npm run release:notes -- --check && npm run sbom:prod -- --check && npm run prisma:generate && npm test && npm run build && npm run build:server",
    "cli": "node scripts/agentic-cli.mjs",
    "knowledge:import:docx": "node scripts/knowledge/import_docx_refs.mjs",
    "benchmarks:api": "node scripts/benchmarks/run_api_regression.mjs",
    "distill:doctor": "node scripts/distill/doctor.mjs",
    "distill:run:full": "node scripts/distill/run_full_pass.mjs",
    "dev:sidecar": "cargo run --manifest-path rust/sidecar/Cargo.toml",
    "dev:api": "tsx watch src/server/index.ts",
    "dev:desktop": "concurrently -k \"npm run dev\" \"wait-on tcp:5173 && electron electron/main.mjs\"",
    "bootstrap": "node scripts/bootstrap.mjs",
    "start:desktop": "npm run bootstrap && npm run dev:desktop",
    "pack:desktop": "npm run build:desktop && electron-builder --dir",
    "dist:desktop": "npm run build:desktop && electron-builder",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e:desktop-acceptance": "node scripts/playwright/run_electron_desktop_acceptance.mjs",
    "test:e2e:desktop-packaged-launch": "node scripts/playwright/run_packaged_desktop_launch_probe.mjs",
    "test:e2e:desktop-stable": "node scripts/playwright/run_desktop_stable.mjs",
    "test:e2e:desktop-packaged-smoke": "node scripts/playwright/run_packaged_desktop_smoke.mjs",
    "test:e2e:local-attach-existing": "node scripts/playwright/run_local_attach_existing_repo.mjs",
    "test:e2e:followup:status-badge": "node scripts/playwright/run_followup_scenario.mjs --scenario status-badge",
    "test:e2e:followup:progress-bar": "node scripts/playwright/run_followup_scenario.mjs --scenario progress-bar",
    "test:e2e:followup:utility-module": "node scripts/playwright/run_followup_scenario.mjs --scenario utility-module",
    "test:e2e:followup:api-stop": "node scripts/playwright/run_followup_scenario.mjs --scenario api-stop",
    "test:e2e:followup:rename-component": "node scripts/playwright/run_followup_scenario.mjs --scenario rename-component",
    "test:e2e:nightly": "node scripts/playwright/run_nightly_suite.mjs",
    "test:e2e:ui-navigation": "node scripts/playwright/run_ui_navigation_smoke.mjs",
    "test:e2e:settings-deep": "node scripts/playwright/run_settings_deep_test.mjs",
    "test:e2e:console-deep": "node scripts/playwright/run_console_deep_test.mjs",
    "test:e2e:codebase-deep": "node scripts/playwright/run_codebase_deep_test.mjs",
    "test:e2e:projects-deep": "node scripts/playwright/run_projects_deep_test.mjs",
    "test:e2e:work-deep": "node scripts/playwright/run_work_deep_test.mjs",
    "test:e2e:ui-suite": "node scripts/playwright/run_ui_deep_suite.mjs",
    "test:e2e:cli-smoke": "node scripts/playwright/run_cli_companion_smoke.mjs",
    "demo:capture": "node scripts/playwright/run_demo_capture.mjs",
    "demo:render": "node scripts/playwright/render_demo_media.mjs",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "test:e2e:playwright": "bash scripts/playwright/run_e2e_critical_failover.sh",
    "test:e2e:settings:openai-all": "bash scripts/playwright/run_settings_openai_kitchen_sink.sh",
    "test:integration:agent-architecture": "vitest run src/server/services/agentArchitecture.integration.test.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@grpc/grpc-js": "^1.12.6",
    "@grpc/proto-loader": "^0.7.13",
    "@popperjs/core": "2.11.8",
    "@prisma/client": "^6.19.2",
    "@radix-ui/react-accordion": "1.2.3",
    "@radix-ui/react-alert-dialog": "1.1.6",
    "@radix-ui/react-aspect-ratio": "1.1.2",
    "@radix-ui/react-avatar": "1.1.3",
    "@radix-ui/react-checkbox": "1.1.4",
    "@radix-ui/react-collapsible": "1.1.3",
    "@radix-ui/react-context-menu": "2.2.6",
    "@radix-ui/react-dialog": "1.1.6",
    "@radix-ui/react-dropdown-menu": "2.1.6",
    "@radix-ui/react-hover-card": "1.1.6",
    "@radix-ui/react-label": "2.1.2",
    "@radix-ui/react-menubar": "1.1.6",
    "@radix-ui/react-navigation-menu": "1.2.5",
    "@radix-ui/react-popover": "1.1.6",
    "@radix-ui/react-progress": "1.1.2",
    "@radix-ui/react-radio-group": "1.2.3",
    "@radix-ui/react-scroll-area": "1.2.3",
    "@radix-ui/react-select": "2.1.6",
    "@radix-ui/react-separator": "1.1.2",
    "@radix-ui/react-slider": "1.2.3",
    "@radix-ui/react-slot": "1.1.2",
    "@radix-ui/react-switch": "1.1.3",
    "@radix-ui/react-tabs": "1.1.3",
    "@radix-ui/react-toggle": "1.1.2",
    "@radix-ui/react-toggle-group": "1.1.2",
    "@radix-ui/react-tooltip": "1.1.8",
    "@tanstack/react-query": "^5.75.5",
    "@testing-library/dom": "^10.4.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "3.6.0",
    "dotenv": "^16.4.7",
    "embla-carousel-react": "8.6.0",
    "fastify": "^5.8.4",
    "input-otp": "1.4.2",
    "lucide-react": "0.487.0",
    "mermaid": "^11.13.0",
    "next-themes": "0.4.6",
    "react": "18.3.1",
    "react-day-picker": "8.10.1",
    "react-dnd": "16.0.1",
    "react-dnd-html5-backend": "16.0.1",
    "react-dom": "18.3.1",
    "react-hook-form": "7.55.0",
    "react-markdown": "^10.1.0",
    "react-popper": "2.3.0",
    "react-resizable-panels": "4.9.0",
    "react-responsive-masonry": "2.7.1",
    "react-slick": "0.31.0",
    "recharts": "2.15.2",
    "remark-gfm": "^4.0.1",
    "sonner": "2.0.3",
    "tailwind-merge": "3.2.0",
    "tw-animate-css": "1.3.8",
    "vaul": "1.1.2",
    "yaml": "^2.8.3",
    "zod": "^3.24.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "4.1.12",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.13.10",
    "@vitejs/plugin-react": "4.7.0",
    "@vitest/coverage-v8": "^3.2.4",
    "concurrently": "^9.1.2",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "eslint": "^10.1.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "^29.0.1",
    "playwright-core": "^1.58.2",
    "prettier": "^3.8.1",
    "prisma": "^6.19.2",
    "tailwindcss": "4.1.12",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript-eslint": "^8.57.2",
    "vite": "6.3.5",
    "vitest": "^3.0.8",
    "wait-on": "^8.0.3"
  },
  "overrides": {
    "@prisma/config": {
      "effect": "^3.21.0"
    }
  },
  "pnpm": {
    "overrides": {
      "vite": "6.3.5"
    }
  },
  "build": {
    "appId": "com.neilslab.agenticcoding",
    "productName": "Agentic Workforce",
    "afterSign": "scripts/notarize.mjs",
    "icon": "build-resources/icon.png",
    "asarUnpack": [
      "dist-sidecar/**/*",
      "node_modules/.prisma/**/*",
      "node_modules/@prisma/**/*"
    ],
    "files": [
      "dist/**/*",
      "dist-server/**/*",
      "dist-sidecar/**/*",
      "electron/**/*",
      "prisma/**/*",
      "proto/**/*",
      "package.json",
      "node_modules/.prisma/**/*",
      "node_modules/**/*"
    ],
    "directories": {
      "buildResources": "build-resources",
      "output": "release"
    },
    "extraResources": [
      {
        "from": "node_modules/.prisma",
        "to": "node_modules/.prisma",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "node_modules/@prisma/client",
        "to": "node_modules/@prisma/client",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "icon": "build-resources/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build-resources/entitlements.mac.plist",
      "entitlementsInherit": "build-resources/entitlements.mac.plist"
    },
    "win": {
      "icon": "build-resources/icon.ico",
      "target": [
        "nsis",
        "zip"
      ]
    },
    "linux": {
      "icon": "build-resources/icon.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development",
      "maintainer": "Neilslab",
      "synopsis": "Desktop coding agent for local repositories",
      "description": "Agentic Workforce is a desktop coding agent for real local repositories with managed execution, verification, and evidence-rich review."
    }
  }
}
